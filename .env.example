# Configuration minimale pour test
TELEGRAM_TOKEN=token
VIP_CHAT_ID=-id_token
MONGO_URI=db_url
BASE_URL=http://localhost:3000
PORT=3000
SESSION_SECRET=dev-secret-key-change-in-production-12345
PAYPAL_MODE=sandbox
LOG_LEVEL=info
NODE_ENV=development

# Variables PayPal (optionnelles pour test)
PAYPAL_CLIENT_ID=test_client_id
PAYPAL_CLIENT_SECRET=test_client_secret
PAYPAL_WEBHOOK_ID=test_webhook_id

# IDs des plans d'abonnement PayPal (requis pour l'auto-renouvellement)
# Voir PAYPAL_SUBSCRIPTIONS.md pour la configuration
PAYPAL_PLAN_ID_MONTHLY=P-XXXXXXXXXXXXXXXXXXXX
PAYPAL_PLAN_ID_QUARTERLY=P-YYYYYYYYYYYYYYYYYYYY
PAYPAL_PLAN_ID_SIXMONTH=P-ZZZZZZZZZZZZZZZZZZZZ
PAYPAL_PLAN_ID_YEARLY=P-WWWWWWWWWWWWWWWWWWWW

# Variables Revolut (optionnelles pour test)
REVOLUT_API_KEY=test_api_key
REVOLUT_WEBHOOK_SECRET=test_webhook_secret

# Variables Stripe (optionnelles pour test)
STRIPE_SECRET_KEY=test_secret_key
STRIPE_WEBHOOK_SECRET=test_webhook_secret
